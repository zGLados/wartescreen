# FACEIT API Configuration
# Kopiere diese Datei zu .env und trage deine Werte ein

# FACEIT API Key (erhältlich auf https://developers.faceit.com/)
FACEIT_API_KEY=dein-api-key-hier

# Server Port (optional, Standard: 3000)
PORT=3000

# Admin-Interface Zugangsdaten (WICHTIG: Ändere das Passwort!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dein-sicheres-passwort-hier

# Veto-Anzeige aktivieren (true/false)
SHOW_VETO=false

# Refresh-Intervall in Millisekunden
REFRESH_INTERVAL=5000

# YouTube Playlist für Hintergrund-Videos (empfohlen)
# Beispiel: https://www.youtube.com/playlist?list=PLxxxxxxxxxxxxxxxxxxxxxx
# Oder einzelnes Video: https://www.youtube.com/watch?v=xxxxxxxx
YOUTUBE_PLAYLIST_URL=
