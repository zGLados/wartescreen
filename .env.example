# FACEIT API Configuration
# Copy this file to .env and enter your values

# FACEIT API Key (available at https://developers.faceit.com/)
FACEIT_API_KEY=your-api-key-here

# Server Port (optional, default: 3000)
PORT=3000

# Admin Interface Credentials (IMPORTANT: Change the password!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Enable Veto Display (true/false)
SHOW_VETO=false

# Refresh Interval in milliseconds
REFRESH_INTERVAL=5000

# PostgreSQL Database Configuration (CS Demo Manager)
# Connection details for your CS Demo Manager PostgreSQL database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=csdm
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-database-password-here

# Enable/Disable PostgreSQL Stats (true/false)
# If true, player stats will be pulled from CS Demo Manager database
# If false, falls back to FACEIT API
USE_POSTGRES_STATS=true

# Season Configuration
# SEASON_START_DATE: When the regular season began (format: YYYY-MM-DD)
# PLAYOFF_START_DATE: When playoffs began (format: YYYY-MM-DD)
# Adjust these dates for each new season to split Regular Season / Playoffs stats
# Example for Season 57:
SEASON_START_DATE=2026-04-06
PLAYOFF_START_DATE=2026-05-26
